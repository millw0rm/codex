+#[serde(deny_unknown_fields)]
+struct PoolToml {
+    #[serde(default)]
+    default_strategy: Option<String>,
+    #[serde(default)]
+    fallback_cooldown_seconds: Option<u64>,
+    profiles: Vec<PoolProfileToml>,
