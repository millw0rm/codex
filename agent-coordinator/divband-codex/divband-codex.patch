+fn process_output_preserves_structured_metadata() {
+    let result = CursorSessionProcessOutput {
+        stdout: LimitedOutput {
+            bytes: b"cursor answer".to_vec(),
+            truncated: false,
+        },
+        stderr: LimitedOutput {
+            bytes: Vec::new(),
